async def send_morning_reports():
    now = datetime.now()
    current_time = now.strftime("%H:%M")
    today = now.date().isoformat()
    yesterday = (now.date() - timedelta(days=1)).isoformat()

    async with aiosqlite.connect(DB_NAME) as db:

        async with db.execute("SELECT id, morning_time FROM users") as cur:
            users = await cur.fetchall()

        for user_id, morning_time in users:

            if not morning_time:
                continue

            report_time = datetime.strptime(morning_time, "%H:%M").time()

            if now.hour != report_time.hour or now.minute != report_time.minute:
                 continue

            # задачи на сегодня
            async with db.execute("""
                SELECT text, is_main
                FROM tasks
                WHERE user_id=? AND date=? AND done=0
            """, (user_id, today)) as cur2:
                tasks_today = await cur2.fetchall()

            # прогресс вчера
            async with db.execute("""
                SELECT done
                FROM tasks
                WHERE user_id=? AND date=?
            """, (user_id, yesterday)) as cur3:
                tasks_yesterday = await cur3.fetchall()

            total = len(tasks_yesterday)
            done = sum(t[0] for t in tasks_yesterday)
            progress = int((done / total) * 100) if total > 0 else 0

            text = "☀️ Доброе утро!\n\n"

            if tasks_today:
                text += "Сегодня у вас:\n"
                index = 1
                for task_text, is_main in tasks_today:
                    star = "⭐ " if is_main else ""
                    text += f"{index}. {star}{task_text}\n"
                    index += 1
            else:
                text += "Сегодня задач нет.\n"

            text += f"\n📊 Прогресс вчера: {progress}%\n"
            text += "\nПоехали 🔥"

            await bot.send_message(user_id, text)
async def send_evening_report_for_user(user_id):
    now = datetime.now()
    today = now.date().isoformat()

    async with aiosqlite.connect(DB_NAME) as db:

        # 📊 считаем прогресс за день
        async with db.execute("""
            SELECT done FROM tasks
            WHERE user_id=? AND date=?
        """, (user_id, today)) as cur:
            all_tasks = await cur.fetchall()

        total = len(all_tasks)
        done_count = sum(t[0] for t in all_tasks)
        percent = int((done_count / total) * 100) if total > 0 else 0
        filled = percent // 10
        bar = "█" * filled + "░" * (10 - filled)
        # 🎨 статус
        if percent == 100 and total > 0:
            status_emoji = "🏆"
            status_text = "Идеально. Машина."
        elif percent >= 75:
            status_emoji = "🟩"
            status_text = "Очень достойно."
        elif percent >= 50:
            status_emoji = "🟨"
            status_text = "Неплохо."
        elif percent >= 25:
            status_emoji = "🟧"
            status_text = "Разгон идёт."
        else:
            status_emoji = "🟥"
            status_text = "Завтра реванш."

        # получаем невыполненные
        async with db.execute("""
            SELECT id, text
            FROM tasks
            WHERE user_id=? AND date=? AND done=0
        """, (user_id, today)) as cur2:
            tasks = await cur2.fetchall()

        text = (
            f"🌙 Итоги дня\n\n"
            f"{bar} {percent}% {status_emoji}\n"
            f"{status_text}\n\n"
        )

        if not tasks:
            await bot.send_message(
                user_id,
                text + "👏 Все задачи выполнены!"
            )
            return

        text += "Невыполненные задачи:\n"

        keyboard = []
        index = 1

        for task_id, task_text in tasks:
            text += f"{index}. {task_text}\n"

            keyboard.append([
                InlineKeyboardButton(
                    text=f"{index} ➡ Перенести",
                    callback_data=f"move_{task_id}"
                ),
                InlineKeyboardButton(
                    text=f"{index} 🗑 Удалить",
                    callback_data=f"delete_{task_id}"
                )
            ])

            index += 1
            keyboard.append([
