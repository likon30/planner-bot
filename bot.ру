async def check_reminders():
    now = datetime.now()
    current_date = now.date().isoformat()

    async with aiosqlite.connect(DB_NAME) as db:
        async with db.execute("""
            SELECT id, user_id, text, time, warned, notified
            FROM tasks
            WHERE date=? AND time IS NOT NULL AND done=0
        """, (current_date,)) as cur:
            tasks = await cur.fetchall()

        for task_id, user_id, text, task_time, warned, notified in tasks:

            # Получаем настройку пользователя
            async with db.execute(
                "SELECT remind_before FROM users WHERE id=?",
                (user_id,)
            ) as cur2:
                row = await cur2.fetchone()
                remind_before = row[0] if row else 10

            task_datetime = datetime.strptime(
                f"{current_date} {task_time}",
                "%Y-%m-%d %H:%M"
            )

            # 🔔 Предупреждение
            if not warned and now >= task_datetime - timedelta(minutes=remind_before):
                await bot.send_message(
                    user_id,
                    f"🔔 Через {remind_before} минут:\n{text}"
                )
                await db.execute(
                    "UPDATE tasks SET warned=1 WHERE id=?",
                    (task_id,)
                )

            # ⏰ Основное напоминание
            if not notified and now >= task_datetime:
                await bot.send_message(
                    user_id,
                    f"⏰ Напоминание:\n{text}"
                )
                await db.execute(
                    "UPDATE tasks SET notified=1 WHERE id=?",
                    (task_id,)
                )

        await db.commit()

async def reminder_loop():
    # даём базе точно создаться
    await asyncio.sleep(2)

    while True:
        try:
            await check_reminders()
        except Exception as e:
            print("Reminder error:", e)

        await asyncio.sleep(30)
async def morning_loop():
