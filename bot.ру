@dp.message(AddTask.ask_time)
async def handle_time_choice(message: Message, state: FSMContext):

    if message.text == "Без времени":
        data = await state.get_data()

        async with aiosqlite.connect(DB_NAME) as db:
            await db.execute(
                "INSERT INTO tasks (id, user_id, text, date) VALUES (?, ?, ?, ?)",
                (str(uuid.uuid4()), message.from_user.id, data["text"], data["date"])
            )
            await db.commit()

        await state.clear()  # 🔥 обязательно очищаем состояние

        await message.answer(
            "Задача добавлена без времени 👌",
            reply_markup=main_menu()
        )
        return  # 🔥 важно остановить выполнение

    if message.text == "⏰ Да":
        await state.set_state(AddTask.waiting_time)
        await message.answer("Введите время HH:MM")


@dp.message(AddTask.waiting_time)
async def save_with_time(message: Message, state: FSMContext):
    try:
        datetime.strptime(message.text, "%H:%M")
    except:
        await message.answer("Формат HH:MM")
        return

    data = await state.get_data()

    async with aiosqlite.connect(DB_NAME) as db:
        await db.execute(
            "INSERT INTO tasks (id, user_id, text, date, time) VALUES (?, ?, ?, ?, ?)",
            (str(uuid.uuid4()), message.from_user.id, data["text"], data["date"], message.text)
        )
