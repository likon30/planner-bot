# ================= DASHBOARD =================

async def render_dashboard(user_id, target_date):
    async with aiosqlite.connect(DB_NAME) as db:
        async with db.execute("""
            SELECT id, text, done, is_main, time
            FROM tasks
            WHERE user_id=? AND date=date(?)
            ORDER BY is_main DESC, done ASC
        """, (user_id, target_date)) as cur:
            tasks = await cur.fetchall()

    divider = "───────────────"
    text = divider + "\n"
    text += f"{target_date}\n\n"

    if not tasks:
        text += "Задач нет.\n"
        text += divider
        return text, None

    total = len(tasks)
    done = sum(t[2] for t in tasks)
    percent = int((done / total) * 100)
    bar = "█" * (percent // 10) + "░" * (10 - percent // 10)

    text += f"Прогресс\n{bar} {percent}%\n\n"

    keyboard = []
    index = 1

    for task_id, task_text, done_flag, is_main, task_time in tasks:
        mark = "✓" if done_flag else "☐"
        star = "⭐ " if is_main else ""
        time_prefix = f"{task_time} " if task_time else ""

        text += f"{index}. {mark} {time_prefix}{star}{task_text}\n"

        if not done_flag and target_date == datetime.now().date().isoformat():
            keyboard.append([
                InlineKeyboardButton(text=f"{index} ✅", callback_data=f"done_{task_id}"),
                InlineKeyboardButton(text=f"{index} ⭐", callback_data=f"main_{task_id}"),
                InlineKeyboardButton(text=f"{index} 🗑", callback_data=f"delete_{task_id}")
            ])

        index += 1

    text += divider
    reply_markup = InlineKeyboardMarkup(inline_keyboard=keyboard) if keyboard else None
    return text, reply_markup


async def send_dashboard(chat_id, target_date):
    text, markup = await render_dashboard(chat_id, target_date)
    await bot.send_message(chat_id, text, reply_markup=markup)


