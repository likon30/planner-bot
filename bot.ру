@dp.message(Command("start"))
async def start(message: Message, state: FSMContext):

    conn = await get_db()

    await conn.execute(
        "INSERT INTO users (id) VALUES ($1) ON CONFLICT (id) DO NOTHING",
        message.from_user.id
    )

    await conn.close()

    await message.answer("Planner v1.3 запущен 👌", reply_markup=main_menu())

    await state.set_state(SetTimezone.waiting_time)

    await message.answer(
        "Напишите текущее время у вас в формате HH:MM\n"
        "Например: 14:35"
    )

@dp.message(SetTimezone.waiting_time)
async def save_timezone(message: Message, state: FSMContext):
    try:
        user_time = datetime.strptime(message.text.strip(), "%H:%M")
    except ValueError:
        await message.answer("Введите время в формате HH:MM\nНапример: 14:35")
        return

    server_utc = datetime.utcnow()

    utc_minutes = server_utc.hour * 60 + server_utc.minute
    user_minutes = user_time.hour * 60 + user_time.minute

    delta_minutes = user_minutes - utc_minutes

    if delta_minutes < -720:
        delta_minutes += 1440
    elif delta_minutes > 720:
        delta_minutes -= 1440

    offset = round(delta_minutes / 60)

    conn = await get_db()

    await conn.execute(
        "UPDATE users SET timezone_offset = $1 WHERE id = $2",
        offset,
        message.from_user.id
    )

    await conn.close()

    await state.clear()

    await message.answer(
        f"Часовой пояс сохранён ✅ (UTC {offset:+})",
        reply_markup=main_menu()
    )
