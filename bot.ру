async def send_weekly_report():
    now = datetime.now()

    # отправляем в воскресенье в 19:00
    if now.weekday() != 6 or now.hour != 19 or now.minute != 0:
        return

    async with aiosqlite.connect(DB_NAME) as db:
        async with db.execute("SELECT id FROM users") as cur:
            users = await cur.fetchall()

        for (user_id,) in users:

            week_start = (now.date() - timedelta(days=6))
            week_start_iso = week_start.isoformat()

            async with db.execute("""
                SELECT date, done
                FROM tasks
                WHERE user_id=? AND date>=?
            """, (user_id, week_start_iso)) as cur2:
                tasks = await cur2.fetchall()

            if not tasks:
                continue

            day_stats = {}
            for task_date, done in tasks:
                day_stats.setdefault(task_date, [0, 0])
                day_stats[task_date][0] += 1
                day_stats[task_date][1] += done

            percentages = []
            for date, (total, done_count) in day_stats.items():
                percent = int((done_count / total) * 100)
                percentages.append(percent)

            avg = int(sum(percentages) / len(percentages))

            best = max(percentages)
            worst = min(percentages)

            text = (
