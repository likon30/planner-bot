# ================= ADD TASK =================

class AddTask(StatesGroup):
    choosing_day = State()
    waiting_text = State()
    ask_time = State()
    waiting_time = State()


@dp.message(F.text == "➕ Добавить задачу")
async def add_start(message: Message, state: FSMContext):
    await state.set_state(AddTask.choosing_day)
    await message.answer("Выберите день:", reply_markup=day_menu())


@dp.message(AddTask.choosing_day)
async def choose_day_add(message: Message, state: FSMContext):

    now = await get_user_now(message.from_user.id)
    today = now.date()

    if message.text == "📍 Сегодня":
        selected_date = today
    elif message.text == "📍 Завтра":
        selected_date = today + timedelta(days=1)
    elif message.text == "📍 На неделю":
        selected_date = today + timedelta(days=7)
    else:
        await state.clear()
        await message.answer("Главное меню", reply_markup=main_menu())
        return

    await state.update_data(date=selected_date.isoformat())
    await state.set_state(AddTask.waiting_text)

    await message.answer("Введите текст задачи:", reply_markup=None)


@dp.message(AddTask.waiting_text)
async def save_text(message: Message, state: FSMContext):
    await state.update_data(text=message.text)
    await state.set_state(AddTask.ask_time)
    await message.answer("Добавить напоминание ко времени?", reply_markup=remind_menu())


@dp.message(AddTask.ask_time)
async def handle_time_choice(message: Message, state: FSMContext):

    data = await state.get_data()

    if message.text == "Без времени":

        conn = await get_db()

        await conn.execute(
            "INSERT INTO tasks (id, user_id, text, date) VALUES ($1, $2, $3, $4)",
            str(uuid.uuid4()),
            message.from_user.id,
            data["text"],
            data["date"]
        )

        await conn.close()

        await state.clear()
        await message.answer("Задача добавлена 👌", reply_markup=main_menu())
        return

    if message.text == "⏰ Да":
        await state.set_state(AddTask.waiting_time)
        await message.answer("Введите время HH:MM")
        return


@dp.message(AddTask.waiting_time)
async def save_with_time(message: Message, state: FSMContext):
    try:
        datetime.strptime(message.text, "%H:%M")
    except:
        await message.answer("Формат HH:MM")
        return

    data = await state.get_data()

    conn = await get_db()

    await conn.execute(
        "INSERT INTO tasks (id, user_id, text, date, time) VALUES ($1, $2, $3, $4, $5)",
        str(uuid.uuid4()),
        message.from_user.id,
        data["text"],
        data["date"],
        message.text
    )

    await conn.close()

    await state.clear()
    await message.answer("Задача добавлена ⏰", reply_markup=main_menu())

# ================= DASHBOARD =================

async def render_dashboard(user_id, target_date):

    conn = await get_db()

    rows = await conn.fetch(
        """
        SELECT id, text, done, is_main, time
        FROM tasks
        WHERE user_id = $1 AND date = $2
        ORDER BY is_main DESC, done ASC
        """,
        user_id,
        target_date
    )

    await conn.close()

    divider = "───────────────"
    text = divider + "\n"
    text += f"{target_date}\n\n"

    if not rows:
        text += "Задач нет.\n"
        text += divider
        return text, None

    total = len(rows)
    done_count = sum(row["done"] for row in rows)
    percent = int((done_count / total) * 100)
    bar = "█" * (percent // 10) + "░" * (10 - percent // 10)

    text += f"Прогресс\n{bar} {percent}%\n\n"

    keyboard = []
    index = 1

    user_now = await get_user_now(user_id)

    for row in rows:
        task_id = row["id"]
        task_text = row["text"]
        done_flag = row["done"]
        is_main = row["is_main"]
        task_time = row["time"]

        mark = "✓" if done_flag else "☐"
        star = "⭐ " if is_main else ""
        time_prefix = f"{task_time} " if task_time else ""

        text += f"{index}. {mark} {time_prefix}{star}{task_text}\n"

        if not done_flag and target_date == user_now.date().isoformat():
            keyboard.append([
                InlineKeyboardButton(text=f"{index} ✅", callback_data=f"done_{task_id}"),
                InlineKeyboardButton(text=f"{index} ⭐", callback_data=f"main_{task_id}"),
                InlineKeyboardButton(text=f"{index} 🗑", callback_data=f"delete_{task_id}")
            ])

        index += 1

    text += divider

    reply_markup = InlineKeyboardMarkup(inline_keyboard=keyboard) if keyboard else None
    return text, reply_markup


async def send_dashboard(chat_id, target_date):
    text, markup = await render_dashboard(chat_id, target_date)
    await bot.send_message(chat_id, text, reply_markup=markup)

