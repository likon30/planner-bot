# ================= REMINDERS =================

async def check_reminders():

    server_utc = datetime.utcnow()

    conn = await get_db()

    rows = await conn.fetch(
        """
        SELECT id, user_id, text, time, warned, notified, date
        FROM tasks
        WHERE time IS NOT NULL AND done = 0
        """
    )

    for row in rows:

        task_id = row["id"]
        user_id = row["user_id"]
        text = row["text"]
        task_time = row["time"]
        warned = row["warned"]
        notified = row["notified"]
        task_date = row["date"]

        offset = await get_user_offset(user_id)
        user_now = server_utc + timedelta(hours=offset)

        if task_date != user_now.date():
            continue

        task_datetime = datetime.strptime(
            f"{task_date} {task_time}",
            "%Y-%m-%d %H:%M"
        )

        user_row = await conn.fetchrow(
            "SELECT remind_before FROM users WHERE id = $1",
            user_id
        )

        remind_before = user_row["remind_before"] if user_row else 10

        if not warned and user_now >= task_datetime - timedelta(minutes=remind_before):

            await bot.send_message(
                user_id,
                f"🔔 Через {remind_before} минут:\n{text}"
            )

            await conn.execute(
                "UPDATE tasks SET warned = 1 WHERE id = $1",
                task_id
            )

        if not notified and user_now >= task_datetime:

            await bot.send_message(
                user_id,
                f"⏰ Напоминание:\n{text}"
            )

            await conn.execute(
                "UPDATE tasks SET notified = 1 WHERE id = $1",
                task_id
            )

    await conn.close()

async def reminder_loop():
    await asyncio.sleep(2)

    while True:
        try:
            await check_reminders()
        except Exception as e:
            print("Reminder error:", e)

        await asyncio.sleep(30)

# ================= MORNING REPORT =================

async def send_morning_reports():

    conn = await get_db()

    users = await conn.fetch(
        "SELECT id, morning_time FROM users"
    )

    for user in users:

        user_id = user["id"]
        morning_time = user["morning_time"]

        if not morning_time:
            continue

        offset = await get_user_offset(user_id)
        now = datetime.utcnow() + timedelta(hours=offset)

        report_time = datetime.strptime(morning_time, "%H:%M").time()

        if now.hour != report_time.hour or now.minute != report_time.minute:
            continue

        today = now.date()
        yesterday = today - timedelta(days=1)

        tasks_today = await conn.fetch(
            """
            SELECT text, is_main
            FROM tasks
            WHERE user_id = $1 AND date = $2 AND done = 0
            """,
            user_id,
            today
        )

        tasks_yesterday = await conn.fetch(
            """
            SELECT done
            FROM tasks
            WHERE user_id = $1 AND date = $2
            """,
            user_id,
            yesterday
        )

        total = len(tasks_yesterday)
        done_count = sum(row["done"] for row in tasks_yesterday)
        progress = int((done_count / total) * 100) if total > 0 else 0

        text = "☀️ Доброе утро!\n\n"

        if tasks_today:
            text += "Сегодня у вас:\n"
            index = 1
            for row in tasks_today:
                star = "⭐ " if row["is_main"] else ""
                text += f"{index}. {star}{row['text']}\n"
                index += 1
        else:
            text += "Сегодня задач нет.\n"

        text += f"\n📊 Прогресс вчера: {progress}%\n"
        text += "\nПоехали 🔥"

        await bot.send_message(user_id, text)

    await conn.close()


async def morning_loop():
    while True:
        try:
            await send_morning_reports()
        except Exception as e:
            print("Morning error:", e)

        await asyncio.sleep(60)

# ================= EVENING REPORT =================

async def send_evening_report_for_user(user_id):

    offset = await get_user_offset(user_id)
    now = datetime.utcnow() + timedelta(hours=offset)
    today = now.date()

    conn = await get_db()

    all_tasks = await conn.fetch(
        """
        SELECT done
        FROM tasks
        WHERE user_id = $1 AND date = $2
        """,
        user_id,
        today
    )

    total = len(all_tasks)
    done_count = sum(row["done"] for row in all_tasks)
    percent = int((done_count / total) * 100) if total > 0 else 0

    filled = percent // 10
    bar = "█" * filled + "░" * (10 - filled)

    if percent == 100 and total > 0:
        status_emoji = "🏆"
        status_text = "Идеально. Машина."
    elif percent >= 75:
        status_emoji = "🟩"
        status_text = "Очень достойно."
    elif percent >= 50:
        status_emoji = "🟨"
        status_text = "Неплохо."
    elif percent >= 25:
        status_emoji = "🟧"
        status_text = "Разгон идёт."
    else:
        status_emoji = "🟥"
        status_text = "Завтра реванш."

    tasks = await conn.fetch(
        """
        SELECT id, text
        FROM tasks
        WHERE user_id = $1 AND date = $2 AND done = 0
        """,
        user_id,
        today
    )

    text = (
        f"🌙 Итоги дня\n\n"
        f"{bar} {percent}% {status_emoji}\n"
        f"{status_text}\n\n"
    )

    if not tasks:
        await bot.send_message(user_id, text + "👏 Все задачи выполнены!")
        await conn.close()
        return

    text += "Невыполненные задачи:\n"

    keyboard = []
    index = 1

    for row in tasks:
        task_id = row["id"]
        task_text = row["text"]

        text += f"{index}. {task_text}\n"

        keyboard.append([
            InlineKeyboardButton(
                text=f"{index} ➡ Перенести",
                callback_data=f"move_{task_id}"
            ),
            InlineKeyboardButton(
                text=f"{index} 🗑 Удалить",
                callback_data=f"delete_{task_id}"
            )
        ])

        index += 1

    keyboard.append([
        InlineKeyboardButton(text="➡ Перенести все", callback_data="move_all"),
        InlineKeyboardButton(text="🗑 Очистить день", callback_data="delete_all")
    ])

    await bot.send_message(
        user_id,
        text,
        reply_markup=InlineKeyboardMarkup(inline_keyboard=keyboard)
    )

    await conn.close()

