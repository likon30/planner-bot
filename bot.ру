# ================= WEEKLY REPORT =================

async def send_weekly_report_for_user(user_id):

    offset = await get_user_offset(user_id)
    now = datetime.utcnow() + timedelta(hours=offset)

    week_start = now.date() - timedelta(days=6)

    conn = await get_db()

    tasks = await conn.fetch(
        """
        SELECT date, done
        FROM tasks
        WHERE user_id = $1 AND date >= $2
        """,
        user_id,
        week_start
    )

    if not tasks:
        await bot.send_message(
            user_id,
            "📅 За последнюю неделю задач не было."
        )
        await conn.close()
        return

    day_stats = {}

    for row in tasks:
        task_date = row["date"]
        done = row["done"]

        if task_date not in day_stats:
            day_stats[task_date] = [0, 0]

        day_stats[task_date][0] += 1
        day_stats[task_date][1] += done

    percentages = []

    for total, done_count in day_stats.values():
        percent = int((done_count / total) * 100)
        percentages.append(percent)

    avg = int(sum(percentages) / len(percentages))
    best = max(percentages)
    worst = min(percentages)

    text = (
        "📅 Итоги недели\n\n"
        f"Средний прогресс: {avg}%\n"
        f"Лучший день: {best}%\n"
        f"Самый слабый день: {worst}%\n\n"
        "Продолжаем рост 🚀"
    )

    await bot.send_message(user_id, text)

    await conn.close()

async def send_weekly_reports():

    conn = await get_db()

    users = await conn.fetch("SELECT id FROM users")

    for user in users:
        await send_weekly_report_for_user(user["id"])

    await conn.close()


async def weekly_loop():
    while True:
        try:
            now = datetime.utcnow()

            # Воскресенье 19:00 UTC
            if now.weekday() == 6 and now.hour == 19 and now.minute == 0:
                await send_weekly_reports()

        except Exception as e:
            print("Weekly error:", e)

        await asyncio.sleep(60)

# ================= CLEANUP =================

async def cleanup_old_tasks():
    while True:
        try:
            cutoff_date = datetime.utcnow().date() - timedelta(days=14)

            conn = await get_db()

            await conn.execute(
                "DELETE FROM tasks WHERE date < $1",
                cutoff_date
            )

            await conn.close()

        except Exception as e:
            print("Cleanup error:", e)

        await asyncio.sleep(86400)

# ================= RUN =================

async def main():

    await init_db()

    asyncio.create_task(reminder_loop())
    asyncio.create_task(morning_loop())
    asyncio.create_task(evening_loop())
    asyncio.create_task(weekly_loop())
    asyncio.create_task(cleanup_old_tasks())

    await dp.start_polling(bot)


if __name__ == "__main__":
    asyncio.run(main())
























