# ================= DATABASE =================

async def get_db():
    return await asyncpg.connect(DATABASE_URL)


async def init_db():
    print("INIT DB START")

    conn = await get_db()

    await conn.execute("""
        CREATE TABLE IF NOT EXISTS users (
            id BIGINT PRIMARY KEY,
            remind_before INTEGER DEFAULT 10,
            morning_time TEXT DEFAULT '09:00',
            evening_time TEXT DEFAULT '21:00',
            timezone_offset INTEGER DEFAULT 0
        );
    """)

    await conn.execute("""
        CREATE TABLE IF NOT EXISTS tasks (
            id TEXT PRIMARY KEY,
            user_id BIGINT,
            text TEXT,
            date DATE,
            time TEXT,
            done INTEGER DEFAULT 0,
            is_main INTEGER DEFAULT 0,
            notified INTEGER DEFAULT 0,
            warned INTEGER DEFAULT 0
        );
    """)

    await conn.close()

    print("INIT DB DONE")

# ================= USER TIME =================

async def get_user_offset(user_id: int):
    conn = await get_db()

    row = await conn.fetchrow(
        "SELECT timezone_offset FROM users WHERE id = $1",
        user_id
    )

    await conn.close()

    if row:
        return row["timezone_offset"]
    return 0


async def get_user_now(user_id: int):
    offset = await get_user_offset(user_id)
    return datetime.utcnow() + timedelta(hours=offset)
